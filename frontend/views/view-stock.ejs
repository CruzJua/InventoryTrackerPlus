<!DOCTYPE html>
<html lang="en">
    <head>
        <title>Inventory Tracker+</title>
        <link rel="stylesheet" href="/css/site.css" />
        <link rel="stylesheet" href="/css/inventory.css">
    </head>
    <body>
        <%- include("partials/header.ejs") %>
        <main class="inventory-wrapper">
            <header class="inventory-header">
                <h2>View Current Stock</h2>
            </header>
            <section>
                <p>This is the page to view the current stock</p>
                <p>It should be a very dynamic page with a list of current items in the businesses inventory</p>
            </section>
            <div class="seperator">
            <div class="inventory-grid">
                <% for (stock of inventoryList) { %>
                <div class="inventory-item">
                    <img <%= stock.imageUrl ? `src=${stock.imageUrl}` : '' %> alt="Image of <%= stock.stock_name %>">
                    <h3><a href="/modify-stock/<%=stock._id%>"><%= stock.stock_name %></a></h3>
                    <p>Current Quantity: <%= stock.quantity %></p>
                    <p class="restock-amount">Restock when Current Quantity is less or equal to: <%= stock.min_to_restock %></p>
                    <div class="inventory-actions">
                        <a href="/modify-stock/<%=stock._id%>">Edit</a>
                        <a href="/delete-stock/<%=stock._id%>" onclick="return confirm('Delete this item?');">Delete</a>
                    </div>
                </div>
                <%}%>
            </div>
            <div class="add-item">
                <h3>Add a new item to stock</h3>
                <p>Click the button below to add a new item to stock</p>
                <a href="/create-stock"><button class="btn btn-primary">Add New Item</button></a>
            </div>
            </div>
        </main>
        <%-include("partials/footer.ejs")%>
    </body>
</html>