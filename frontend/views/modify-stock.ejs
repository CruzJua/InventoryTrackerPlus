<!--Build this page out to be a submenu of the view-stock page.-->
<!DOCTYPE html>
<html lang="en">

<head>
    <title>Inventory Tracker+</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="stylesheet" href="/css/modify-stock.css" />
    <script src="/js/modify-stock.js" defer></script>
</head>

<body>
    <%- include("partials/header.ejs") %>
        <main class="modify-container">
            <h2>
                <%= stock.stock_name %> — Edit Stock
            </h2>

            <%# Stock image preview %>
                <% if (stock.imageUrl) { %>
                    <div class="image-preview">
                        <img src="<%= stock.imageUrl %>" alt="Image of <%= stock.stock_name %>">
                    </div>
                    <% } %>

                        <form class="modify-form" action="/update-stock/<%= stock._id %>" method="POST"
                            enctype="multipart/form-data">

                            <label for="stock_name">Stock Name</label>
                            <input type="text" id="stock_name" name="stock_name" value="<%= stock.stock_name %>"
                                required>

                            <label for="quantity">Quantity</label>
                            <input type="number" id="quantity" name="quantity" value="<%= stock.quantity %>" min="0"
                                required>

                            <label for="min_to_restock">Restock When Quantity ≤</label>
                            <input type="number" id="min_to_restock" name="min_to_restock"
                                value="<%= stock.min_to_restock %>" min="0">

                            <label for="image">Image</label>
                            <%# Pass the current imageUrl as a data attribute for the live preview %>
                                <input type="file" id="image" name="image" accept="image/*"
                                    data-current-url="<%= stock.imageUrl || '' %>">
                                <%# Hidden field so the server knows which Cloudinary asset to delete %>
                                    <input type="hidden" name="imagePublicId" value="<%= stock.imagePublicId || '' %>">
                                    <%# Keep the current URL around so the server uses it if no new file uploaded %>
                                        <input type="hidden" name="imageUrl" value="<%= stock.imageUrl || '' %>">

                                        <label for="description">Description</label>
                                        <textarea id="description" name="description" rows="4"
                                            placeholder="Enter a description..."><%= stock.description || '' %></textarea>

                                        <% const standardKeys=['_id', '__v' , 'stock_name' , 'quantity'
                                            , 'min_to_restock' , 'imageUrl' , 'imagePublicId' , 'description' ]; %>
                                            <% const customFields=Object.entries(stock).filter(([k])=>
                                                !standardKeys.includes(k));
                                                %>

                                                <% if (customFields.length> 0) { %>
                                                    <div class="custom-fields-section">
                                                        <p class="custom-fields-label">Custom Fields</p>
                                                        <% for (const [key, value] of customFields) { %>
                                                            <label for="cf_<%= key %>">
                                                                <%= key %>
                                                            </label>
                                                            <input type="text" id="cf_<%= key %>" name="<%= key %>"
                                                                value="<%= value %>">
                                                            <% } %>
                                                    </div>
                                                    <% } %>

                                                        <button type="submit" class="btn-update">Save Changes</button>
                        </form>

                        <div class="inventory-actions">
                            <a href="/inventory">← Back to Inventory</a>
                            <a class="btn-delete" href="/delete-stock/<%= stock._id %>"
                                onclick="return confirm('Are you sure you want to delete this stock item?');">
                                Delete Item
                            </a>
                        </div>
        </main>
        <%- include("partials/footer.ejs") %>
</body>

</html>