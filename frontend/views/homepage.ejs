<!DOCTYPE html>
<html lang="en">
    <head>
        <title>Inventory Tracker+</title>
        <link rel="stylesheet" href="/css/site.css" />
        <link rel = "stylesheet" href= "/css/homepage.css"/>
    </head>
    <body>
        <%- include("partials/header.ejs") %>

        <header class="home-hero">
            <h1>Welcome to Inventory Tracker+</h1>
            <p>Your lightweight inventory management tool</p>
            <a href="/inventory" class="home-cta">View Inventory</a>
        </header>

        <main class="home-content">
            <section class="feature-section">
                <div class="feature-text">
                    <h2>Track Your Inventory</h2>
                    <p>Get a comprehensive view of all your current stock in a beautifully organized grid. Easily spot what you have and what you're running low on.</p>
                </div>
                <img src="/images/view-stock.png" alt="Inventory Grid" class="feature-image" />
            </section>

            <section class="feature-section reverse">
                <div class="feature-text">
                    <h2>Manage Stock Effortlessly</h2>
                    <p>Add new items or modify existing ones with our intuitive forms. Keep descriptions, quantities, and custom fields organized and up to date.</p>
                </div>
                <img src="/images/edit-stock.png" alt="Edit Stock Form" class="feature-image" />
            </section>

            <section class="feature-section upcoming">
                <div class="feature-text">
                    <h2><span class="badge">Coming Soon</span> Low Stock Alerts</h2>
                    <p>Never run out of essential items again. Soon, Inventory Tracker+ will automatically alert you when quantities drop below your minimum restock threshold.</p>
                </div>
\                <div class="feature-image placeholder">
                    <p>Alerts Interface (In Development)</p>
                </div>
            </section>

            <section class="feature-section upcoming reverse">
                <div class="feature-text">
                    <h2><span class="badge">Coming Soon</span> Custom Stock Templates</h2>
                    <p>Streamline your workflow with custom templates. Soon you'll be able to create presets for frequently added items, saving you time and ensuring consistency across your inventory.</p>
                </div>

                <div class="feature-image placeholder">
                    <p>Template Builder (In Development)</p>
                </div>
            </section>
        </main>

        <%-include("partials/footer.ejs")%>
    </body>
</html>